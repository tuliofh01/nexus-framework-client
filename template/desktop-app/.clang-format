# Nexus Framework house style — LLVM base, 4-space indent, 110 columns.
BasedOnStyle: LLVM
Language: Cpp
Standard: c++20
IndentWidth: 4
ColumnLimit: 110
AccessModifierOffset: -4
AllowShortFunctionsOnASingleLine: Inline
AlwaysBreakTemplateDeclarations: Yes
BreakBeforeBraces: Attach
DerivePointerAlignment: false
PointerAlignment: Left
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^"'          # project headers first
    Priority: 1
  - Regex: '^<(SDL3|imgui|implot|imnodes|sol|pybind11)'
    Priority: 2           # vendored framework packages
  - Regex: '.*'
    Priority: 3           # standard library / everything else
SortIncludes: CaseSensitive
SpacesBeforeTrailingComments: 2
