{
  "nexus": {
    "configVersion": 2,
    "generatedBy": "nexus-framework-client",
    "template": "desktop-app"
  },
  "project": {
    "name": "{{projectName}}",
    "windowTitle": "{{projectName}} - built with The Nexus Framework",
    "version": "0.1.0",
    "cppStandard": "20",
    "createdAt": "{{createdAt}}"
  },
  "scriptProtection": {
    "enabled": {{scriptProtectionEnabled}},
    "salt": "{{scriptProtectionSalt}}",
    "algorithm": "nxs-v1"
  },
  "targets": {
    "desktop": {
      "backend": "sdl3",
      "renderer": "opengl3",
      "minCMake": "3.24"
    }
  },
  "features": {
    "imgui": true,
    "implot": true,
    "imnodes": true,
    "lua": { "enabled": true, "binding": "sol2", "scriptDir": "scripts" },
    "python": {
      "enabled": true,
      "embedding": "pybind11",
      "sourceDir": "python",
      "requirements": "requirements.txt"
    },
    "tsXhtmlDsl": { "enabled": true, "sourceDir": "ui" }
  },
  "blueprint": {
    "flow": "blueprint.json",
    "editor": "imnodes"
  },
  "build": {
    "outputDir": "../../builds/framework/{{projectName}}",
    "presets": "CMakePresets.json"
  }
}
