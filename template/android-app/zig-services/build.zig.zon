.{
    // Zig 0.14+ requires an enum-literal name and a fingerprint.
    // TemplateEngine renders {{projectName}} before the first build.
    .name = .{{projectName}},
    .version = "0.1.0",
    .fingerprint = 0xd3a1c0ffee000001,
    .paths = .{""},
    // No zig-fetched dependencies: ImGui/SDL/sol2/Lua for the Android app
    // are built by the Gradle/CMake pipeline; Zig owns only the JNI glue
    // and the C-ABI exports.
    .dependencies = .{},
}
