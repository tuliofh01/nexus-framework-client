{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "android-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../../builds/framework/{{projectName}}/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_SYSTEM_NAME": "Android",
        "CMAKE_ANDROID_STL_TYPE": "c++_shared",
        "CMAKE_ANDROID_API": "26",
        "ANDROID": "ON"
      }
    },
    {
      "name": "android-arm64",
      "displayName": "Android arm64-v8a (Debug)",
      "inherits": "android-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_ANDROID_ARCH_ABI": "arm64-v8a"
      }
    },
    {
      "name": "android-x86_64",
      "displayName": "Android x86_64 emulator (Debug)",
      "inherits": "android-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_ANDROID_ARCH_ABI": "x86_64"
      }
    }
  ],
  "buildPresets": [
    { "name": "android-arm64", "configurePreset": "android-arm64" },
    { "name": "android-x86_64", "configurePreset": "android-x86_64" }
  ]
}
