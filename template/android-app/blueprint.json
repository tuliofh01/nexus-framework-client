{
  "$schema": "https://nexus.dev/schemas/blueprint-1.json",
  "name": "{{projectName}} flow",
  "description": "Langflow-style app graph (design-time codegen, not n8n runtime automation). Edit in :app Blueprint Editor; ProjectGenerator consumes this file when emitting builds/framework/<name>/.",
  "editor": { "tool": "imnodes", "version": "0.5", "grid_snap": 16, "paradigm": "langflow" },
  "nodes": [
    {
      "id": "py-functions",
      "type": "python.module",
      "position": { "x": 40, "y": 120 },
      "data": {
        "source": "app/src/main/python/functions.py",
        "exports": ["evaluate"],
        "packages": ["numpy"]
      }
    },
    {
      "id": "model-registry",
      "type": "cpp.model",
      "position": { "x": 320, "y": 40 },
      "data": {
        "class": "nxs::model::FunctionRegistry",
        "catalog": ["sine", "cosine", "gaussian", "polynomial", "damped", "sinc"]
      }
    },
    {
      "id": "controller-plot",
      "type": "cpp.controller",
      "position": { "x": 320, "y": 220 },
      "data": {
        "class": "nxs::controller::PlotController",
        "settings": { "xMin": -10, "xMax": 10, "sampleCount": 512 }
      }
    },
    {
      "id": "view-plotter",
      "type": "ui.page",
      "position": { "x": 620, "y": 120 },
      "data": {
        "source": "ui/ui.xhtml",
        "controllerScript": "ui/ui.ts#PlotterPage",
        "widgets": ["combo", "list", "slider", "toggle", "plot"]
      }
    },
    {
      "id": "lua-panels",
      "type": "lua.script",
      "position": { "x": 620, "y": 320 },
      "data": { "source": "scripts/panels.lua", "hotkeys": ["F1", "L"] }
    }
  ],
  "edges": [
    { "id": "e1", "source": "py-functions", "target": "controller-plot", "port": "evaluate" },
    { "id": "e2", "source": "controller-plot", "target": "model-registry", "port": "sampleCache" },
    { "id": "e3", "source": "model-registry", "target": "view-plotter", "port": "activeCurves" },
    { "id": "e4", "source": "view-plotter", "target": "controller-plot", "port": "commands" },
    { "id": "e5", "source": "lua-panels", "target": "controller-plot", "port": "commands" }
  ]
}
