{
  "$schema": "https://nexus.dev/schemas/blueprint-1.json",
  "name": "{{projectName}} flow",
  "description": "General-purpose Nexus app graph. Optional plotter sample under examples/plotter/.",
  "editor": { "tool": "imnodes", "version": "0.5", "grid_snap": 16, "paradigm": "langflow" },
  "nodes": [
    {
      "id": "py-helpers",
      "type": "python.module",
      "position": { "x": 40, "y": 120 },
      "data": {
        "source": "app/src/main/python/helpers.py",
        "exports": ["greeting"],
        "packages": []
      }
    },
    {
      "id": "model-app",
      "type": "cpp.model",
      "position": { "x": 320, "y": 40 },
      "data": {
        "class": "nxs::model::AppModel",
        "fields": ["counter", "greeting"]
      }
    },
    {
      "id": "controller-app",
      "type": "cpp.controller",
      "position": { "x": 320, "y": 220 },
      "data": {
        "class": "nxs::controller::AppController",
        "commands": ["increment", "decrement", "reset"]
      }
    },
    {
      "id": "view-main",
      "type": "ui.page",
      "position": { "x": 620, "y": 120 },
      "data": {
        "source": "ui/ui.xhtml",
        "controllerScript": "ui/ui.ts#AppPage",
        "widgets": ["panel", "label", "button", "row"]
      }
    },
    {
      "id": "lua-panels",
      "type": "lua.script",
      "position": { "x": 620, "y": 320 },
      "data": { "source": "scripts/panels.lua", "hotkeys": ["F1"] }
    }
  ],
  "edges": [
    { "id": "e1", "source": "py-helpers", "target": "controller-app", "port": "greeting" },
    { "id": "e2", "source": "controller-app", "target": "model-app", "port": "state" },
    { "id": "e3", "source": "model-app", "target": "view-main", "port": "bindings" },
    { "id": "e4", "source": "view-main", "target": "controller-app", "port": "commands" },
    { "id": "e5", "source": "lua-panels", "target": "controller-app", "port": "commands" }
  ]
}
