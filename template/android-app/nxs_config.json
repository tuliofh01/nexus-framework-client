{
  "nexus": {
    "configVersion": 2,
    "generatedBy": "nexus-framework-client",
    "template": "android-app"
  },
  "project": {
    "name": "{{projectName}}",
    "applicationId": "com.nexus.plotter",
    "windowTitle": "{{projectName}} - built with The Nexus Framework",
    "version": "0.1.0",
    "cppStandard": "20"
  },
  "targets": {
    "android": {
      "backend": "sdl3",
      "renderer": "opengles3",
      "minSdk": 26,
      "targetSdk": 35,
      "ndkAbis": ["arm64-v8a", "x86_64"],
      "minCMake": "3.24"
    }
  },
  "features": {
    "imgui": true,
    "implot": true,
    "imnodes": true,
    "lua": { "enabled": true, "binding": "sol2", "scriptDir": "scripts" },
    "python": {
      "enabled": true,
      "embedding": "chaquopy",
      "sourceDir": "app/src/main/python",
      "packages": ["numpy"]
    },
    "djinni": {
      "enabled": true,
      "idl": "djinni/plotter.djinni",
      "generatedDir": "djinni-generated"
    },
    "tsXhtmlDsl": { "enabled": true, "sourceDir": "ui" }
  },
  "blueprint": {
    "flow": "blueprint.json",
    "editor": "imnodes"
  },
  "build": {
    "outputDir": "../../builds/framework/{{projectName}}",
    "gradleModule": "app",
    "presets": "CMakePresets.json"
  }
}
