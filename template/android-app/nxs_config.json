{
  "nexus": {
    "configVersion": 2,
    "generatedBy": "nexus-framework-client",
    "template": "android-app"
  },
  "project": {
    "name": "{{projectName}}",
    "applicationId": "com.nexus.{{packageName}}",
    "windowTitle": "{{projectName}} - built with The Nexus Framework",
    "version": "0.1.0",
    "cppStandard": "20",
    "createdAt": "{{createdAt}}"
  },
  "scriptProtection": {
    "enabled": {{scriptProtectionEnabled}},
    "salt": "{{scriptProtectionSalt}}",
    "algorithm": "nxs-v1"
  },
  "targets": {
    "android": {
      "backend": "sdl3",
      "renderer": "opengles3",
      "minSdk": 26,
      "targetSdk": 35,
      "ndkAbis": ["arm64-v8a", "x86_64"],
    }
  },
  "features": {
    "imgui": true,
    "implot": true,
    "imnodes": true,
    "lua": { "enabled": true, "binding": "sol2", "scriptDir": "scripts" },
    "python": {
      "enabled": true,
      "embedding": "chaquopy",
      "sourceDir": "app/src/main/python",
      "packages": []
    },
    "tsXhtmlDsl": { "enabled": true, "sourceDir": "ui" },
    "examples": {
      "plotter": { "enabled": false, "path": "examples/plotter" }
    }
  },
  "blueprint": {
    "flow": "blueprint.json",
    "editor": "imnodes"
  },
  "flows": {
    "path": "flows/flows.json",
    "enabled": true
  },
  "build": {
    "outputDir": "../../builds/framework/{{projectName}}",
    "gradleModule": "app"
  }
}
