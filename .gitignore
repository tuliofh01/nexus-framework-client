### builds/ — track structure + docs; ignore generated apps and deploy binaries ###
# Ignore all contents under builds/, then re-include placeholders and docs.
builds/**
!builds/README.txt
!builds/LAYOUT.md
!builds/client/
!builds/client/.gitkeep
!builds/client/README.txt
!builds/framework/
!builds/framework/.gitkeep
!builds/framework/README.txt
!builds/framework/_fixture/
!builds/framework/_fixture/**
# Heavy Compose Desktop deploy outputs (never commit)
builds/client/app/
builds/client/packages/
# Generated scaffolded native apps under framework/ (anything except keep/docs/_fixture)
# Already covered by builds/**; explicit note for clarity — do not un-ignore project trees.
